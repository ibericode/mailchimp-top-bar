{
    "name": "dannyvankooten/wp-mailchimp-top-bar",
    "type": "wordpress-plugin",
    "description": "Adds an opt-in bar to the top of your site.",
    "keywords": [
        "wordpress",
        "mailchimp"
    ],
    "homepage": "https://wordpress.org/plugins/mailchimp-top-bar/",
    "license": "GPL-3.0+",
    "authors": [
        {
            "name": "Danny van Kooten",
            "email": "hi@dannyvankooten.com",
            "homepage": "https://dannyvankooten.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "scripts": {
        "check-syntax": "find . -name '*.php' -not -path './vendor/*' -not -path './node_modules/*' -print0 | xargs -0 -n1 php -l",
        "check-codestyle": "vendor/bin/phpcs",
        "static-analysis": "vendor/bin/phpstan analyse",
        "wp-plugin-checks": "wp plugin check mailchimp-top-bar --ignore-warnings --ignore-codes=hidden_files,application_detected"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.11",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
