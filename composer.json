{
    "name": "dannyvankooten/wp-mailchimp-top-bar",
    "type": "wordpress-plugin",
    "description": "Adds an opt-in bar to the top of your site.",
    "keywords": [
        "wordpress",
        "mailchimp"
    ],
    "homepage": "https://wordpress.org/plugins/mailchimp-top-bar/",
    "license": "GPL-3.0+",
    "authors": [
        {
            "name": "Danny van Kooten",
            "email": "hi@dannyvankooten.com",
            "homepage": "https://dannyvankooten.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "scripts": {
        "check-syntax": "find . -path ./vendor -prune -o -type f -name '*.php' -print0 | xargs -0 -n1 -P4 php --define error_reporting=-1 -l -n | (! grep -v \"No syntax errors detected\" )",
        "check-codestyle": "phpcs -ns",
        "static-analysis": "phpstan analyse",
        "wp-plugin-checks": "wp plugin check mailchimp-top-bar --ignore-warnings --ignore-codes=hidden_files,application_detected"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.11",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
